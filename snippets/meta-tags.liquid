  {%- endunless -%}
  "name": {{ seo_name | json }},
  "sku": {{ product.selected_or_first_available_variant.sku | default: product.id | json }},
  "brand": {"@type": "Brand", "name": {{ product.vendor | default: shop.name | json }}},
  "description": {{ product.metafields.custom.seo_description.value | default: product.description | strip_html | truncate: 200 | json }},
  "image": [{% if product.featured_image %}{{ product.featured_image | image_url: width: 1024 | json }}{% endif %}],
  "offers": {
    "@type": "Offer",
    "url": {{ canonical_url | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": "{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition"
    {%- assign compare_at = product.selected_or_first_available_variant.compare_at_price -%}
    {%- if compare_at == blank -%}{%- assign compare_at = product.compare_at_price_min -%}{%- endif -%}
    {%- if compare_at != blank and compare_at > product.selected_or_first_available_variant.price -%}
    ,"priceSpecification": [
      {
        "@type": "PriceSpecification",
        "price": "{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "priceType": "https://schema.org/SalePrice"
      },
      {
        "@type": "PriceSpecification",
        "price": "{{ compare_at | divided_by: 100.0 }}",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "priceType": "https://schema.org/ListPrice"
      }
    ]
    {%- endif -%}
  }
  ,"keywords": {{ product.tags | join: ', ' | json }}
  {%- comment -%}
    material: Shopify native field (shopify.material) preferred; fall back to custom namespace.
    Returns just the value (handles both list and single-line types).
  {%- endcomment -%}
  {%- assign mat_value = product.metafields.shopify.material.value -%}
  {%- if mat_value == blank -%}{%- assign mat_value = product.metafields.custom.material.value -%}{%- endif -%}
  {%- if mat_value == blank and product.description contains 'Acrylic' -%}{%- assign mat_value = 'Acrylic' -%}{%- endif -%}
  {%- if mat_value != blank -%}
  ,"material": {{ mat_value | json }}
  {%- endif -%}
  {%- comment -%}
    size: shopify.size preferred; fall back to variant option label.
  {%- endcomment -%}
  {%- assign size_value = product.metafields.shopify.size.value -%}
  {%- if size_value == blank -%}{%- assign size_value = product.selected_or_first_available_variant.option1 -%}{%- endif -%}
  {%- if size_value != blank -%}
  ,"size": {{ size_value | json }}
  {%- endif -%}
  {%- if product.metafields.custom.return_days.value != blank -%}
  ,"hasMerchantReturnPolicy": {
    "@type": "MerchantReturnPolicy",
    "applicableCountry": "US",
    "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
    "merchantReturnDays": {{ product.metafields.custom.return_days.value | json }},
    "returnMethod": "https://schema.org/ReturnByMail",
    "returnFees": "https://schema.org/FreeReturn",
    "returnPolicyUrl": "https://moonleehome.com/policies/refund-policy"
  }
  {%- endif -%}
  {%- if product.metafields.judgeme.rating != blank and product.metafields.judgeme.rating.value != '0' -%}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ product.metafields.judgeme.rating.value | json }},
    "reviewCount": {{ product.metafields.judgeme.review_count.value | default: 0 | json }},
    "bestRating": 5
  }
  {%- endif -%}
  {%- comment -%}
    MOONLEE size specification: per-finger measurements for each size variant.
    This enables AI agents to recommend the correct size based on user measurements.

    DYNAMIC MATCHING (2026-07-02):
    Products match automatically via shopify.nail-shape metafield GID.
    For Oval → default Short Oval; add handle to medium-oval set to override.
    For Square → default Short Square; add handle to short-squoval set to override.
    New Almond/Round/Stiletto products → just set metafield, zero code changes.
  {%- endcomment -%}
  {%- if product.variants.size > 1 and product.options contains 'Size' -%}
  {%- liquid
    assign mold = ''
    assign shapes = product.metafields.shopify.nail-shape.value
    for s in shapes
      if s contains '175525331015'
        assign mold = 'almond'
      elsif s contains '173929365575'
        assign mold = 'oval'
      elsif s contains '174344208455'
        assign mold = 'square'
      elsif s contains '194267611207'
        assign mold = 'round'
      elsif s contains '175525593159'
        assign mold = 'stiletto'
      endif
    endfor
    if mold == 'oval'
      if product.handle == 'color-pop-handmade-press-on-nails'
        assign mold = 'medium-oval'
      else
        assign mold = 'short-oval'
      endif
    elsif mold == 'square'
      if product.handle contains 'pink-sugar' or product.handle contains 'caramel-torte' or product.handle contains 'rainbow-candy' or product.handle contains 'mocha-cream' or product.handle contains 'blue-sugar'
        assign mold = 'short-squoval'
      else
        assign mold = 'short-square'
      endif
    elsif mold == 'stiletto'
      if product.handle contains 'strawberry-bloom'
        assign mold = 'long-stiletto'
      endif
    endif
  %}
