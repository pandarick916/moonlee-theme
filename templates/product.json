                "custom_liquid_a4ktEL": {
                  "type": "custom-liquid",
                  "name": "measure fingers",
                  "settings": {
                    "custom_liquid": "<!-- Nail Size Finder v7 — Adaptive Calibration + Size Recommendation -->\n<style>\n  .nail-finder-widget,\n  #nf-modal-1,\n  #nf-modal-2 {\n    font-family: var(--font-body--family);\n    font-weight: var(--font-body--weight);\n  }\n\n  .nail-finder-widget *,\n  #nf-modal-1 *,\n  #nf-modal-2 * {\n    font-family: inherit;\n    font-weight: inherit;\n  }\n\n  .nail-finder-widget button {\n    border-color: color-mix(in srgb, currentColor 80%, transparent);\n  }\n</style>\n\n<div class=\"nail-finder-widget\" style=\"margin: 1px 0;\">\n  <button onclick=\"NailFinder.open()\"\n    style=\"background:none; border:2px solid rgba(0,0,0,0.1); padding:8px 16px; cursor:pointer; letter-spacing:0.05em; width:100%; box-sizing:border-box; display:block;\">\n    Not Sure Your Size? 2-Step Online Sizing!\n  </button>\n</div>\n\n\n\n<!-- Step 1 弹窗 -->\n<div id=\"nf-modal-1\"\n  style=\"display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:9999; align-items:center; justify-content:center;\">\n  <div id=\"nf-box-1\" style=\"background:#fff; border-radius:8px; padding:28px 24px; position:relative; box-sizing:border-box; will-change:transform;\">\n    <button onclick=\"NailFinder.close()\"\n      style=\"position:absolute; top:12px; right:16px; background:none; border:none; font-size:20px; cursor:pointer;\">✕</button>\n    <p style=\"margin:0 0 4px; font-size:15px; font-weight:600;\">Step 1 — Calibrate Screen</p>\n    <p id=\"nf-cal-hint\" style=\"margin:0 0 14px; font-size:12px; color:#888;\"></p>\n    <div id=\"nf-card-wrap\" style=\"margin-bottom:4px; display:flex; justify-content:flex-start;\">\n      <div id=\"nf-card-rect\" style=\"background:rgba(91,143,230,0.15); border:2px solid #5b8fe6; border-radius:3px; will-change:transform; position:relative; box-sizing:border-box;\">\n        <span id=\"nf-card-label\" style=\"position:absolute;bottom:4px;right:6px;font-size:9px;color:#5b8fe6;\"></span>\n      </div>\n    </div>\n    <p id=\"nf-cal-axis-hint\" style=\"font-size:10px;color:#aaa;margin:0 0 12px;\"></p>\n    <label style=\"font-size:12px;color:#555;\">Scale: <strong id=\"nf-card-scale\">100</strong>%</label><br>\n    <input type=\"range\" id=\"nf-card-slider\" min=\"40\" max=\"200\" value=\"100\" step=\"1\"\n      style=\"width:100%;margin-top:6px;margin-bottom:16px;\"\n      oninput=\"NailFinder.cardSlide(this.value)\">\n    <button onclick=\"NailFinder.confirm()\"\n      style=\"width:100%;padding:10px;background:#333;color:#fff;border:none;font-size:13px;letter-spacing:0.05em;cursor:pointer;border-radius:3px;\">\n      ✓ Matches My Card — Next\n    </button>\n    <button onclick=\"NailFinder.skip()\"\n      style=\"width:100%;padding:8px;background:none;border:none;font-size:12px;color:#aaa;cursor:pointer;margin-top:6px;\">\n      Skip (less accurate)\n    </button>\n  </div>\n</div>\n\n<!-- Step 2 弹窗 -->\n<div id=\"nf-modal-2\"\n  style=\"display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:9999; align-items:flex-start; justify-content:center; overflow-y:auto; padding:40px 0;\">\n  <div style=\"background:#fff;padding:24px 20px;max-width:360px;width:92%;position:relative;border-radius:6px;margin:auto;\">\n    <button onclick=\"NailFinder.close()\"\n      style=\"position:absolute;top:12px;right:16px;background:none;border:none;font-size:20px;cursor:pointer;\">✕</button>\n    <div style=\"display:flex;gap:8px;margin-bottom:20px;\">\n      <div style=\"flex:1;height:3px;background:#e85d75;border-radius:2px;\"></div>\n      <div style=\"flex:1;height:3px;background:#e85d75;border-radius:2px;\"></div>\n    </div>\n    <p style=\"margin:0 0 4px;font-size:15px;font-weight:600;\">Step 2 — Measure Your Nail</p>\n    <p style=\"margin:0 0 16px;font-size:12px;color:#888;\">Place your thumb nail on the ruler. Drag the pink line to match your nail's right edge.</p>\n    <div style=\"position:relative;height:56px;margin-bottom:12px;\">\n      <canvas id=\"nf-nail-ruler\" height=\"56\" style=\"display:block;width:100%;\"></canvas>\n    </div>\n    <div style=\"margin-bottom:16px;\">\n      <label style=\"font-size:12px;color:#555;\">Nail width: <strong id=\"nf-nail-mm\">14</strong> mm</label><br>\n      <input type=\"range\" id=\"nf-nail-slider\" min=\"8\" max=\"22\" value=\"14\" step=\"0.5\"\n        style=\"width:100%;margin-top:6px;\"\n        oninput=\"NailFinder.nailSlide(this.value)\">\n    </div>\n\n    <!-- 推荐尺寸区块 -->\n    <div style=\"background:#fdf6f0;border-radius:8px;padding:14px 16px;margin-bottom:16px;text-align:center;\">\n      <div style=\"font-size:11px;color:#aaa;letter-spacing:0.08em;margin-bottom:4px;\">RECOMMENDED SIZE</div>\n      <div id=\"nf-size-label\" style=\"font-size:2.4rem;font-weight:800;color:#c0665a;line-height:1;\">S</div>\n      <div id=\"nf-size-desc\" style=\"font-size:12px;color:#888;margin-top:4px;\">Most common fit</div>\n    </div>\n\n    <button onclick=\"NailFinder.back()\"\n      style=\"width:100%;padding:8px;background:none;border:1px solid #ddd;font-size:12px;color:#888;cursor:pointer;border-radius:3px;\">\n      ← Re-calibrate\n    </button>\n    <p style=\"font-size:10px;color:#ccc;margin:12px 0 0;text-align:center;\">* Accuracy ±0.5mm after calibration</p>\n  </div>\n</div>\n\n<script>\nwindow.NailFinder = (function () {\n  var _ppmm = null, _cssPPMM = null, _currentScale = 1;\n  var _isMobile = false, _rafCard = null, _rafNail = null, _nailInited = false;\n  var _els = null;\n\n  var sizeChart = [\n    {s:'XS', min:8,    max:10.4, d:'Petite / Small hands'},\n    {s:'S',  min:10.5, max:12.4, d:'Most common fit'},\n    {s:'M',  min:12.5, max:13.4, d:'Average hands ✓ Best seller'},\n    {s:'L',  min:13.5, max:22,   d:'Wider / Larger hands'}\n  ];\n\n  function getSize(mm) {\n    for (var i = 0; i < sizeChart.length; i++) {\n      if (mm >= sizeChart[i].min && mm <= sizeChart[i].max) return sizeChart[i];\n    }\n    return mm > 22 ? {s:'L+', d:'Contact us for custom sizing'} : sizeChart[0];\n  }\n\n  function els() {\n    if (!_els) _els = {\n      modal1:    document.getElementById('nf-modal-1'),\n      modal2:    document.getElementById('nf-modal-2'),\n      box1:      document.getElementById('nf-box-1'),\n      cardRect:  document.getElementById('nf-card-rect'),\n      cardScale: document.getElementById('nf-card-scale'),\n      cardSlider:document.getElementById('nf-card-slider'),\n      calHint:   document.getElementById('nf-cal-hint'),\n      cardLabel: document.getElementById('nf-card-label'),\n      axisHint:  document.getElementById('nf-cal-axis-hint'),\n      nailRuler: document.getElementById('nf-nail-ruler'),\n      nailMM:    document.getElementById('nf-nail-mm'),\n      nailSlider:document.getElementById('nf-nail-slider'),\n      sizeLabel: document.getElementById('nf-size-label'),\n      sizeDesc:  document.getElementById('nf-size-desc')\n    };\n    return _els;\n  }\n\n  function getCSSPPMM() {\n    if (_cssPPMM) return _cssPPMM;\n    var d = document.createElement('div');\n    d.style.cssText = 'width:10mm;position:absolute;visibility:hidden;';\n    document.body.appendChild(d);\n    _cssPPMM = d.offsetWidth / 10;\n    document.body.removeChild(d);\n    return _cssPPMM;\n  }\n\n  function getSaved() {\n    try { var v = localStorage.getItem('moonlee_ppmm'); return v ? parseFloat(v) : null; }\n    catch(e) { return null; }\n  }\n\n  function setupCalibrationUI() {\n    _isMobile = window.innerWidth < 600;\n    var e = els();\n    _currentScale = 1;\n    e.cardSlider.value = 100;\n    e.cardScale.textContent = '100';\n    if (_isMobile) {\n      e.box1.style.width = '85%';\n      e.cardRect.style.cssText += ';width:60px;height:54mm;transform-origin:top center;transform:scaleY(1);';\n      e.cardLabel.textContent = '54mm';\n      e.calHint.innerHTML = 'Place your credit card <strong>upright</strong> next to the blue bar.<br>Drag until the bar height matches the card\\'s short side (54mm).';\n      e.axisHint.textContent = '↕ drag to match card height';\n    } else {\n      e.box1.style.width = '500px';\n      e.cardRect.style.cssText += ';width:85.6mm;height:20mm;transform-origin:left center;transform:scaleX(1);';\n      e.cardLabel.textContent = '85.6mm';\n      e.calHint.innerHTML = 'Place your credit card flat on the blue bar.<br>Drag until the bar width <strong>exactly matches</strong> your card\\'s long side (85.6mm).';\n      e.axisHint.textContent = '← drag to match card width →';\n    }\n  }\n\n  function open() {\n    var saved = getSaved();\n    if (saved) { _ppmm = saved; showStep2(); } else { showStep1(); }\n  }\n  function close() { var e=els(); e.modal1.style.display='none'; e.modal2.style.display='none'; }\n  function showStep1() { var e=els(); e.modal2.style.display='none'; e.modal1.style.display='flex'; setupCalibrationUI(); }\n  function showStep2() {\n    var e=els(); e.modal1.style.display='none'; e.modal2.style.display='flex';\n    setTimeout(function(){\n      if(!_nailInited){ e.nailRuler.width=e.nailRuler.parentElement.offsetWidth; _nailInited=true; }\n      drawNail(parseFloat(e.nailSlider.value));\n    },50);\n  }\n  function cardSlide(val) {\n    _currentScale = parseFloat(val)/100;\n    if(_rafCard) cancelAnimationFrame(_rafCard);\n    _rafCard = requestAnimationFrame(function(){\n      var e=els(); e.cardScale.textContent=val;\n      e.cardRect.style.transform = _isMobile ? 'scaleY('+_currentScale+')' : 'scaleX('+_currentScale+')';\n    });\n  }\n  function confirm() {\n    var rect=els().cardRect;\n    _ppmm = _isMobile ? (rect.offsetHeight*_currentScale)/54 : (rect.offsetWidth*_currentScale)/85.6;\n    try { localStorage.setItem('moonlee_ppmm',_ppmm); } catch(e){}\n    showStep2();\n  }\n  function skip() { _ppmm=getCSSPPMM(); showStep2(); }\n  function back() {\n    try { localStorage.removeItem('moonlee_ppmm'); } catch(e){}\n    _ppmm=null; _nailInited=false; _cssPPMM=null; showStep1();\n  }\n  function drawNail(mm) {\n    mm = parseFloat(mm);\n    var e = els();\n    e.nailMM.textContent = mm;\n    var s = getSize(mm);\n    e.sizeLabel.textContent = s.s;\n    e.sizeDesc.textContent = s.d;\n    var canvas=e.nailRuler, ctx=canvas.getContext('2d');\n    var ppmm=_ppmm||getCSSPPMM(), w=canvas.width, h=canvas.height;\n    ctx.clearRect(0,0,w,h);\n    ctx.strokeStyle='#eee'; ctx.lineWidth=1;\n    ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(w,0); ctx.stroke();\n    var showLabels = ppmm*5>=28;\n    ctx.strokeStyle='#bbb'; ctx.lineWidth=1;\n    ctx.font='10px sans-serif'; ctx.fillStyle='#999';\n    for(var i=0;i<=22;i++){\n      var x=Math.round(i*ppmm); if(x>w) break;\n      var isFive=i%5===0;\n      ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,isFive?22:10); ctx.stroke();\n      if(isFive&&showLabels) ctx.fillText(i+'mm',x+2,34);\n    }\n    var mx=Math.round(mm*ppmm);\n    ctx.strokeStyle='#e85d75'; ctx.lineWidth=2;\n    ctx.beginPath(); ctx.moveTo(mx,0); ctx.lineTo(mx,h); ctx.stroke();\n    ctx.fillStyle='#e85d75';\n    ctx.beginPath(); ctx.moveTo(mx-5,0); ctx.lineTo(mx+5,0); ctx.lineTo(mx,9); ctx.fill();\n  }\n  function nailSlide(val) {\n    if(_rafNail) cancelAnimationFrame(_rafNail);\n    _rafNail = requestAnimationFrame(function(){ drawNail(val); });\n  }\n  return {open:open,close:close,cardSlide:cardSlide,nailSlide:nailSlide,confirm:confirm,skip:skip,back:back};\n})();\n</script>"
