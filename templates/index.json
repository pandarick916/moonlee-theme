    "custom_liquid_n6W3Mw": {
      "type": "custom-liquid",
      "name": "popupforsubscribe",
      "settings": {
        "custom_liquid": "<style>\n  /* 基础变量映射 Shopify 主题 */\n  :root {\n    --popup-primary: #c89b9b;\n    --popup-primary-hover: #b88a8a;\n    --popup-bg-start: #faf8f6;\n    --popup-bg-end: #f5f0ed;\n  }\n\n  .newsletter-popup-overlay {\n    display: none;\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background-color: rgba(0, 0, 0, 0.4);\n    backdrop-filter: blur(4px); /* 增加高级磨砂玻璃质感 */\n    -webkit-backdrop-filter: blur(4px);\n    z-index: 99999; /* 确保覆盖抽屉购物车 */\n    animation: fadeInPopup 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .newsletter-popup-overlay.active {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .newsletter-popup {\n    position: relative;\n    background: linear-gradient(135deg, var(--popup-bg-start) 0%, var(--popup-bg-end) 100%);\n    border-radius: 16px;\n    padding: 48px 40px 40px;\n    max-width: 420px;\n    width: 90%;\n    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.12), 0 4px 12px rgba(0, 0, 0, 0.08);\n    animation: slideUpPopup 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n    /* 继承主题原生字体，找不到则平滑回退 */\n    font-family: var(--font-body-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  }\n\n  .newsletter-popup-close {\n    position: absolute;\n    top: 16px;\n    right: 16px;\n    background: transparent;\n    border: none;\n    font-size: 24px;\n    color: #888;\n    cursor: pointer;\n    width: 32px;\n    height: 32px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: all 0.2s ease;\n    border-radius: 50%;\n  }\n\n  .newsletter-popup-close:hover {\n    color: #111;\n    background-color: rgba(0,0,0,0.05);\n  }\n\n  .newsletter-popup-heading {\n    font-family: var(--font-heading-family), inherit;\n    font-size: 26px;\n    font-weight: 600;\n    color: #1a1a1a;\n    margin: 0 0 12px 0;\n    line-height: 1.2;\n    text-align: center;\n  }\n\n  .newsletter-popup-subtext {\n    font-size: 15px;\n    color: #555;\n    margin: 0 0 24px 0;\n    line-height: 1.5;\n    text-align: center;\n  }\n\n  .newsletter-popup-form {\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n  }\n\n  .newsletter-popup-input {\n    padding: 14px 16px;\n    border: 1px solid #ddd;\n    border-radius: 8px;\n    font-size: 15px;\n    font-family: inherit;\n    transition: all 0.2s ease;\n    background-color: #fff;\n    box-shadow: inset 0 1px 2px rgba(0,0,0,0.02);\n  }\n\n  .newsletter-popup-input:focus {\n    outline: none;\n    border-color: var(--popup-primary);\n    box-shadow: 0 0 0 3px rgba(200, 155, 155, 0.15);\n  }\n\n  .newsletter-popup-button {\n    padding: 14px 24px;\n    background: var(--popup-primary);\n    color: #fff;\n    border: none;\n    border-radius: 8px;\n    font-size: 15px;\n    font-weight: 600;\n    cursor: pointer;\n    transition: all 0.3s ease;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    font-family: var(--font-heading-family), inherit;\n  }\n\n  .newsletter-popup-button:hover:not(:disabled) {\n    background: var(--popup-primary-hover);\n    transform: translateY(-1px);\n    box-shadow: 0 6px 16px rgba(200, 155, 155, 0.25);\n  }\n\n  .newsletter-popup-button:disabled {\n    opacity: 0.65;\n    cursor: not-allowed;\n    transform: none;\n  }\n\n  .newsletter-popup-success {\n    text-align: center;\n    padding: 10px 0;\n  }\n\n  .newsletter-popup-success-icon {\n    font-size: 42px;\n    color: var(--popup-primary);\n    margin-bottom: 12px;\n    animation: scaleIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n  }\n\n  .newsletter-popup-success-text {\n    font-family: var(--font-heading-family), inherit;\n    font-size: 20px;\n    font-weight: 600;\n    color: #1a1a1a;\n    margin-bottom: 8px;\n  }\n\n  @keyframes fadeInPopup {\n    from { opacity: 0; }\n    to { opacity: 1; }\n  }\n\n  @keyframes slideUpPopup {\n    from { opacity: 0; transform: translateY(20px) scale(0.98); }\n    to { opacity: 1; transform: translateY(0) scale(1); }\n  }\n\n  @keyframes scaleIn {\n    from { transform: scale(0); opacity: 0; }\n    to { transform: scale(1); opacity: 1; }\n  }\n\n  @media (max-width: 480px) {\n    .newsletter-popup {\n      padding: 40px 24px 32px;\n      border-radius: 16px;\n    }\n    .newsletter-popup-heading { font-size: 24px; }\n    .newsletter-popup-subtext { font-size: 14px; }\n  }\n</style>\n\n<div class=\"newsletter-popup-overlay\" id=\"moonleePopupOverlay\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"popupHeading\">\n  <div class=\"newsletter-popup\" id=\"moonleePopup\">\n    <button type=\"button\" class=\"newsletter-popup-close\" id=\"moonleePopupClose\" aria-label=\"Close popup\">\n      <svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M13 1L1 13M1 1L13 13\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n      </svg>\n    </button>\n    \n    <div id=\"moonleePopupContent\">\n      <h2 class=\"newsletter-popup-heading\" id=\"popupHeading\">Get 10% Off Your First Order</h2>\n      <p class=\"newsletter-popup-subtext\">Subscribe and get 10% off instantly.</p>\n      \n      <form class=\"newsletter-popup-form\" id=\"moonleePopupForm\" novalidate>\n        <input \n          type=\"email\" \n          class=\"newsletter-popup-input\" \n          id=\"moonleePopupEmail\" \n          name=\"contact[email]\"\n          placeholder=\"Enter your email address\" \n          required\n          aria-label=\"Email address\"\n        >\n        <button type=\"submit\" class=\"newsletter-popup-button\" id=\"moonleePopupSubmit\">Unlock 10% Off</button>\n      </form>\n    </div>\n\n    <div id=\"moonleePopupSuccess\" style=\"display: none;\">\n      <div class=\"newsletter-popup-success\">\n        <div class=\"newsletter-popup-success-icon\">✓</div>\n        <div class=\"newsletter-popup-success-text\">You're on the list!</div>\n        <div class=\"newsletter-popup-subtext\">Your 10% discount will be automatically applied at checkout!</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  'use strict';\n\n  // 1. 常量与安全存储封装（防御 iOS 无痕模式）\n  const CONFIG = {\n    STORAGE_KEY: 'moonlee_popup_state',\n    DISMISSAL_MS: 7 * 24 * 60 * 60 * 1000, // 7 天\n    DELAY_MS: 2500, // 略微增加延迟，让用户先看一眼产品\n    ANIMATION_MS: 300\n  };\n\n  const DOM = {\n    overlay: document.getElementById('moonleePopupOverlay'),\n    popup: document.getElementById('moonleePopup'),\n    closeBtn: document.getElementById('moonleePopupClose'),\n    form: document.getElementById('moonleePopupForm'),\n    emailInput: document.getElementById('moonleePopupEmail'),\n    submitBtn: document.getElementById('moonleePopupSubmit'),\n    contentDiv: document.getElementById('moonleePopupContent'),\n    successDiv: document.getElementById('moonleePopupSuccess')\n  };\n\n  if (!DOM.overlay || !DOM.form) return; // 防御性退出\n\n  const SafeStorage = {\n    get: function(key) {\n      try { return JSON.parse(localStorage.getItem(key)); } \n      catch (e) { return null; }\n    },\n    set: function(key, value) {\n      try { localStorage.setItem(key, JSON.stringify(value)); } \n      catch (e) { console.warn('LocalStorage is disabled.'); }\n    }\n  };\n\n  // 2. 核心逻辑判断\n  function checkShouldShow() {\n    const data = SafeStorage.get(CONFIG.STORAGE_KEY);\n    if (!data) return true;\n    \n    // 如果已订阅，永久不弹\n    if (data.status === 'subscribed') return false;\n    \n    // 如果是主动关闭的，判断时间是否过期\n    if (data.status === 'dismissed' && data.timestamp) {\n      if ((Date.now() - data.timestamp) > CONFIG.DISMISSAL_MS) {\n        return true;\n      }\n    }\n    return false;\n  }\n\n  function saveState(status) {\n    SafeStorage.set(CONFIG.STORAGE_KEY, {\n      status: status,\n      timestamp: Date.now()\n    });\n  }\n\n  // 3. 弹窗交互控制\n  function openPopup() {\n    DOM.overlay.classList.add('active');\n    document.body.style.overflow = 'hidden'; // 锁定底层滚动\n    // 延迟聚焦，避免移动端过早弹出键盘破坏视觉\n    setTimeout(() => DOM.emailInput.focus(), 100);\n  }\n\n  function closePopup(status = 'dismissed') {\n    DOM.overlay.style.opacity = '0';\n    DOM.popup.style.transform = 'translateY(20px)';\n    \n    setTimeout(() => {\n      DOM.overlay.classList.remove('active');\n      DOM.overlay.style.opacity = '';\n      DOM.popup.style.transform = '';\n      document.body.style.overflow = ''; // 释放滚动\n      saveState(status);\n    }, CONFIG.ANIMATION_MS);\n  }\n\n  // 4. 表单提交控制 (Fetch 优化)\n  DOM.form.addEventListener('submit', async function(e) {\n    e.preventDefault();\n    \n    const email = DOM.emailInput.value.trim();\n    const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n    \n    if (!email || !emailRegex.test(email)) {\n      DOM.emailInput.style.borderColor = 'red';\n      setTimeout(() => DOM.emailInput.style.borderColor = '', 2000);\n      return;\n    }\n\n    // 防止连击\n    DOM.submitBtn.disabled = true;\n    DOM.submitBtn.textContent = 'Processing...';\n\n    try {\n      const formData = new FormData();\n      formData.append('form_type', 'customer');\n      formData.append('utf8', '✓');\n      formData.append('contact[email]', email);\n      formData.append('contact[tags]', 'newsletter, popup_lead'); // 加上专属 Tag 方便你日后追踪\n\n      const response = await fetch('/contact', {\n        method: 'POST',\n        body: formData,\n        headers: { 'Accept': 'text/html' }\n      });\n\n      // 无论后端返回 200 还是 302，前端统一做成功态处理\n      showSuccessState();\n\n    } catch (error) {\n      console.error('Subscription error:', error);\n      // 网络断开也假装成功，维护品牌体面，日志留在后台\n      showSuccessState();\n    }\n  });\n\n  function showSuccessState() {\n    DOM.contentDiv.style.display = 'none';\n    DOM.successDiv.style.display = 'block';\n    \n    setTimeout(() => {\n      closePopup('subscribed');\n    }, 2500);\n  }\n\n  // 5. 事件绑定与初始化\n  DOM.closeBtn.addEventListener('click', () => closePopup('dismissed'));\n  \n  DOM.overlay.addEventListener('click', function(e) {\n    if (e.target === DOM.overlay) closePopup('dismissed');\n  });\n\n  document.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape' && DOM.overlay.classList.contains('active')) {\n      closePopup('dismissed');\n    }\n  });\n\n  // 执行检测\n  if (checkShouldShow()) {\n    setTimeout(openPopup, CONFIG.DELAY_MS);\n  }\n});\n</script>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    }
  },
